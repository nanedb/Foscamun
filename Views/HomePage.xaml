<Page x:Class="Foscamun2026.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignWidth="780"
      d:DesignHeight="500"
      Title="Home"
      Background="White">
    
     <Grid ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="1.2*" />
            <RowDefinition Height="1.3*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Titolo / welcome -->
        <Viewbox Grid.Row="0"
                 Grid.Column="0"
                 Stretch="Uniform"
                 StretchDirection="Both"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Center">
            <TextBlock Style="{StaticResource H1Inverted}"
                       Padding="10 0 40 0"
                       TextWrapping="Wrap"
                       TextAlignment="Center">
                <Run Text="{DynamicResource WelcomeMessage}"/>
                <Run Text="{DynamicResource YearResource}"/>
            </TextBlock>
        </Viewbox>

        <!-- Banner immagine -->
        <!-- Banner: riempie la riga e non supera la larghezza della Page -->
        <Viewbox Grid.Row="1"
                 HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch"
                 MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Page}}">
                    <Image Source="pack://application:,,,/Resources/Banner.png"
                   Stretch="UniformToFill"/>
        </Viewbox>
        <!-- Area inferiore (vuota o contenuto) -->
        <Border Grid.Row="2"
                Background="{DynamicResource FoscamunBlue}"
                Margin="0 -15 0 0">
            <!-- contenuto inferiore -->
        </Border>
    </Grid>
</Page>