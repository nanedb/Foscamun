<Page x:Class="Foscamun2026.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Home"
      Background="{DynamicResource FoscamunBlue}"
      Foreground="{DynamicResource FoscamunWhite}"
      Height="500" Width="850">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="120" />
        </Grid.RowDefinitions>

        <!-- Titolo / welcome -->
        <TextBlock Style="{StaticResource H1Inverted}"
               Padding="20,50,0,0"
               Margin="-2,-20,-20,-2"
               Grid.Row="0">
      <Run Text="{DynamicResource WelcomeMessage}"/>
      <Run Text="{DynamicResource YearResource}"/>
        </TextBlock>

        <!-- Banner immagine -->
        <Border Grid.Row="1"
            Margin="-2,-2,-20,0">
            <!--ClipToBounds="True">-->
            <Border.Background>
                <ImageBrush ImageSource="pack://application:,,,/Resources/Banner.png"
                    Stretch="UniformToFill"
                    AlignmentY="Bottom"/>
            </Border.Background>
        </Border>

        <!-- Area inferiore con sfondo FoscamunBlue -->
        <Border Grid.Row="2"
            Background="{DynamicResource FoscamunBlue}"
            Margin="-2,0,-20,0">
        </Border>
    </Grid>
</Page>
