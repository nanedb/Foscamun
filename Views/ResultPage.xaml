<UserControl x:Class="Foscamun2026.Views.ResultPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="20">
        <Button Content="Carica Risultati"
                Command="{Binding LoadResultsAsyncCommand}"
                Margin="0,0,0,10"/>
        <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="True" Height="200"/>
    </StackPanel>
</UserControl>
