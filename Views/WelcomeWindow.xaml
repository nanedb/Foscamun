<Window x:Class="Foscamun2026.Views.WelcomeWindow"
        x:Name="Root"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        mc:Ignorable="d"
        Title="Foscamun"
        Height="500" Width="1000"
        WindowStartupLocation="CenterScreen"
        Icon="/Foscamun2026;component/Resources/Foscamun.ico"
        Background="{StaticResource WhiteBrush}">

    <Window.Resources>
        <!-- Converter built-in per comodità (se non presente, puoi dichiararlo in Resources) -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Storyboard x:Key="FrameSlideIn">
            <DoubleAnimation Storyboard.TargetName="MainFrame"
                       Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                       From="300" To="0" Duration="0:0:0.32">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainFrame"
                       Storyboard.TargetProperty="Opacity"
                       From="0" To="1" Duration="0:0:0.22"/>
        </Storyboard>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- assegna un nome alla colonna per poterla modificare dal code-behind -->
            <ColumnDefinition x:Name="LeftColumn" Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Pannello sinistro con gradiente e header hamburger -->
        <Border Grid.Column="0"
            Padding="5"
            BorderBrush="{DynamicResource FoscamunWhite}"
            BorderThickness="0,0,1,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{StaticResource FoscamunDarkBlueColor}" Offset="0" />
                    <GradientStop Color="{StaticResource FoscamunBlueColor}" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel Orientation="Vertical" VerticalAlignment="Top" Cursor="">

                <!-- Hamburger + icona a destra, dentro lo stesso StackPanel dei MenuButton -->
                <Grid Margin="0,0,0,6" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <!-- Colonna principale: occupa tutto lo spazio disponibile -->
                        <ColumnDefinition Width="*" />
                        <!-- Colonna auto per l'icona a destra -->
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--Hamburger button-->
                    <Button Style="{StaticResource MenuButton}"
                            VerticalAlignment="Center"
                            Click="HamburgerBtn_Click"
                            ToolTip="{DynamicResource HamburgerBtn}" Cursor="Hand">
                            <svgc:SvgViewbox Width="20" Height="20"
                                             VerticalAlignment="Center"
                                             Source="pack://application:,,,/Resources/Icons/hamburger.svg"
                                             Stretch="Uniform"
                                             Margin="0,5,0,0"/>
                    </Button>

                    <!-- Icona a destra dell'hamburger: visibile solo quando il pannello è aperto -->
                    <svgc:SvgViewbox Grid.Column="1"
                                     Width="30" Height="30"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Right"
                                     Margin="0,0,10,0"
                                     Source="pack://application:,,,/Resources/Icons/icon.svg"
                                     Stretch="Uniform"
                                     SnapsToDevicePixels="True"
                                     UseLayoutRounding="True"
                                     AutomationProperties.Name="Foscamun logo" Cursor="">
                        <svgc:SvgViewbox.Style>
                            <Style TargetType="svgc:SvgViewbox">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <!-- Nasconde l'icona quando il pannello è collassato -->
                                    <DataTrigger Binding="{Binding IsPaneCollapsed, ElementName=Root}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </svgc:SvgViewbox.Style>
                    </svgc:SvgViewbox>
                </Grid>
                
                <!-- Pulsanti principali: MenuButton (usa lo stile MenuButton definito) -->
                <!-- Ogni Button mostra icona + testo; il testo viene nascosto quando IsPaneCollapsed == true -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Top">
                    
                    <!--Configure button-->
                    <Button Style="{StaticResource MenuButton}"
                            Margin="0,0,0,8"
                            Click="ConfigureBtn_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <svgc:SvgViewbox Width="18" Height="18"
                               Source="pack://application:,,,/Resources/Icons/configure.svg"
                               Stretch="Uniform"
                               Margin="0,0,10,0"/>
                            <TextBlock Text="{DynamicResource ConfigureBtn}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource FoscamunWhite}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPaneCollapsed, ElementName=Root}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!--Next button-->
                    <Button Style="{StaticResource MenuButton}"
                            Margin="0,0,0,8"
                            Click="NextBtn_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <svgc:SvgViewbox Width="18" Height="18"
                                             Source="pack://application:,,,/Resources/Icons/next.svg"
                                             Stretch="Uniform"
                                             Margin="0,0,10,0"/>
                            <TextBlock Text="{DynamicResource NextBtn}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource FoscamunWhite}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPaneCollapsed, ElementName=Root}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <!--Exit button-->
                    <Button Style="{StaticResource MenuButton}"
                            Margin="0,0,0,8"
                            Click="ExitBtn_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <svgc:SvgViewbox Width="18" Height="18"
                                             Source="pack://application:,,,/Resources/Icons/exit.svg"
                                             Stretch="Uniform"
                                             Margin="0,0,10,0"/>
                            <TextBlock x:Name="ExitText"
                                       Text="{DynamicResource ExitBtn}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource FoscamunWhite}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <!-- Nascondi il testo quando IsPaneCollapsed è true -->
                                            <DataTrigger Binding="{Binding IsPaneCollapsed, ElementName=Root}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>


                </StackPanel>

            </StackPanel>
        </Border>

        <!-- Contenuto principale (titolo + banner) -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="120" />
            </Grid.RowDefinitions>

            <TextBlock Style="{StaticResource H1Inverted}"
                       Padding="20,50,0,0"
                       Margin="-2,0,0,0"
                       Grid.Row="0">
                <Run Text="{DynamicResource WelcomeMessage}"/>
                <Run Text="{DynamicResource YearResource}"/>
            </TextBlock>

            <Border Grid.Column="1" Grid.Row="1"
                    Margin="-2,-20"
                    ClipToBounds="True">
                <Border.Background>
                    <ImageBrush ImageSource="pack://application:,,,/Resources/Banner.png"
                                Stretch="UniformToFill"
                                AlignmentX="Center"
                                AlignmentY="Bottom"/>
                </Border.Background>
            </Border>

            <!-- Area sottostante con sfondo FoscamunBlue -->
            <Border Grid.Row="2"
                    Margin="-2,0,0,0"
                    Background="{DynamicResource FoscamunBlue}">
            </Border>


        </Grid>
    </Grid>
</Window>