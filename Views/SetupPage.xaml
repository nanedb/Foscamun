<Page x:Class="Foscamun2026.SetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:Foscamun2026.ViewModels"
      xmlns:properties="clr-namespace:Foscamun2026.Properties"
      mc:Ignorable="d"
      Title="{DynamicResource ConfigurationTitle}"
      Background="{DynamicResource FoscamunBlue}"
      Foreground="{DynamicResource FoscamunWhite}"
      FontFamily ="{DynamicResource FontPrimary}"
      FontSize="18"
      Height="500" Width="800">

    <!-- STILI LOCALI -->
    <Page.Resources>
        <!-- Evidenziazione ListBox -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Background" Value="#22000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LeftAlignedLabelStyle" TargetType="Label">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="Foreground" Value="{DynamicResource FoscamunWhite}"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

    </Page.Resources>

    <!-- LAYOUT PRINCIPALE -->
    <Grid Margin="40">

        <Grid.RowDefinitions>
            <!-- Selected Committee -->
            <RowDefinition Height="Auto"/>
            <!-- Year -->
            <RowDefinition Height="Auto"/>
            <!-- Language -->
            <RowDefinition Height="Auto"/>
            <!-- Committee label -->
           <RowDefinition Height="Auto"/>
            <!-- Committee list + buttons -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SELECTED COMMITTEE -->
        <Label Grid.Row="0" Grid.Column="0"
               Style="{StaticResource LeftAlignedLabelStyle}"
               Content="{DynamicResource SelCommittee}"/>
        <Label Grid.Row="0" Grid.Column="1"
       Content="{Binding Path=SelCommName, Source={x:Static properties:Settings.Default}}"
       HorizontalAlignment="Left"
               Margin="30,0,0,0"
       Foreground="{DynamicResource FoscamunWhite}" />


        <!-- YEAR -->
        <Label Grid.Row="1" Grid.Column="0"
               Style="{StaticResource LeftAlignedLabelStyle}"
               Content="{DynamicResource YearLbl}"/>
        <TextBox x:Name="YearBox"  Grid.Row="1" Grid.Column="1"
                 Background="{DynamicResource FoscamunWhite}"
                 Text="{Binding Source={x:Static properties:Settings.Default},
                                Path=Year,
                                Mode=TwoWay,
                                UpdateSourceTrigger=PropertyChanged}"
                 Margin="30,0,0,0"
                 VerticalContentAlignment="Center"
                 VerticalAlignment="Center" Padding="4"/>

        <!-- LANGUAGE LABEL -->
        <Label Grid.Row="2" Grid.Column="0"
               Style="{StaticResource LeftAlignedLabelStyle}"
               Content="{DynamicResource LanguageLbl}"/>

        <!-- LANGUAGE BUTTONS -->
        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 8 0 0">

            <RadioButton x:Name="EngLangButton"
                         Checked="EngLangButton_Checked"
                         Margin="10 0">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Foscamun2026;component/Resources/24/GB.png"
                           Width="24" Height="24" Margin="0 0 5 0"/>
                    <TextBlock Text="English" FontSize="18"
                               Foreground="{DynamicResource FoscamunWhite}"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="FraLangButton"
                         Checked="FraLangButton_Checked"
                         Margin="10 0">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Foscamun2026;component/Resources/24/FR.png"
                           Width="24" Height="24" Margin="0 0 5 0"/>
                    <TextBlock Text="Français" FontSize="18"
                               Foreground="{DynamicResource FoscamunWhite}"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="EspLangButton"
                         Checked="EspLangButton_Checked"
                         Margin="10 0">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Foscamun2026;component/Resources/24/ES.png"
                           Width="24" Height="24" Margin="0 0 5 0"/>
                    <TextBlock Text="Español" FontSize="18"
                               Foreground="{DynamicResource FoscamunWhite}"/>
                </StackPanel>
            </RadioButton>

        </StackPanel>

        <!-- COMMITTEE LABEL -->
        <Label Grid.Row="3" Grid.Column="0"
               Style="{StaticResource LeftAlignedLabelStyle}"
               Content="{DynamicResource CommitteeLbl}"/>

        <!-- COMMITTEE LIST -->
        <ListBox x:Name="CommitteesListBox"
                 Grid.Row="4" Grid.Column="0"
                 ItemsSource="{Binding Committees}"
                 DisplayMemberPath="Name"
                 SelectedItem="{Binding SelectedCommittee, Mode=TwoWay}"
                 SelectionChanged="CommitteesListBox_SelectionChanged"
                 Margin="0 0 30 0"
                 MinHeight="120"
                 Background="{DynamicResource FoscamunWhite}">
        </ListBox>

        <!-- ACTION BUTTONS -->
        <StackPanel Grid.Row="4" Grid.Column="1"
                    Orientation="Vertical"
                    VerticalAlignment="Top">

            <Button x:Name="AddButton"
                    Click="AddButton_Click"
                    Margin="30 0 0 10">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Foscamun2026;component/Resources/Add_24x24.png"
                           Width="24" Height="24" Margin="0 0 5 0"/>
                    <TextBlock Text="{DynamicResource AddBtn}" Padding="10 5"/>
                </StackPanel>
            </Button>

            <Button x:Name="EditButton"
                    Click="EditButton_Click"
                    Margin="30 0 0 10"
                    IsEnabled="{Binding IsEditCommitteeEnabled}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Foscamun2026;component/Resources/Edit_24x24.png"
                           Width="24" Height="24" Margin="0 0 5 0"/>
                    <TextBlock Text="{DynamicResource EditBtn}" Padding="10 5"/>
                </StackPanel>
            </Button>

            <Button x:Name="RemoveButton"
                    Click="RemoveButton_Click"
                    Margin="30 0 0 10"
                    IsEnabled="{Binding IsEditCommitteeEnabled}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Foscamun2026;component/Resources/Remove_24x24.png"
                           Width="24" Height="24" Margin="0 0 5 0"/>
                    <TextBlock Text="{DynamicResource RemoveBtn}" Padding="10 5"/>
                </StackPanel>
            </Button>

        </StackPanel>

        <!-- NAVIGATION BUTTONS -->
        <!--<StackPanel Grid.Row="5" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0 20 0 0">

            <Button x:Name="BackButton"
                    Click="BackButton_Click"
                    Margin="0 0 20 0"
                    MinWidth="150" MinHeight="50">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Foscamun2026;component/Resources/Previous_24x24.png"
                           Width="24" Height="24" Margin="0 0 10 0"/>
                    <TextBlock Text="{DynamicResource BackBtn}" Padding="5"/>
                </StackPanel>
            </Button>

            <Button x:Name="NextButton"
                    Click="NextButton_Click"
                    MinWidth="150" MinHeight="50">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource NextBtn}" Padding="5"/>
                    <Image Source="/Foscamun2026;component/Resources/Next_24x24.png"
                           Width="24" Height="24" Margin="10 0 0 0"/>
                </StackPanel>
            </Button>

        </StackPanel>-->

    </Grid>

</Page>