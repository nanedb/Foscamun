<Page x:Class="Foscamun2026.Views.SetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:vm="clr-namespace:Foscamun2026.ViewModels"
      xmlns:properties="clr-namespace:Foscamun2026.Properties"
      xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
      mc:Ignorable="d"
      d:DesignWidth="900"
      d:DesignHeight="600"
      d:DataContext="{x:Null}"
      Background="{DynamicResource PrimaryBrush}"
      Foreground="{DynamicResource SurfaceBrush}"
      FontFamily ="{DynamicResource FontPrimary}"
      FontSize="18">

    <!-- STILI LOCALI -->
    <Page.Resources>
        <Style x:Key="LeftAlignedLabelStyle" TargetType="Label">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

    </Page.Resources>

    <!-- LAYOUT PRINCIPALE -->
    <Grid Margin="40 30 40 40">

        <Grid.RowDefinitions>
            <!-- Title -->
            <RowDefinition Height="*"/>
            <!-- Selected Committee -->
            <RowDefinition Height="*"/>
            <!-- Year -->
            <RowDefinition Height="*"/>
            <!-- Language -->
            <RowDefinition Height="*"/>
            <!-- Committee label -->
           <RowDefinition Height="*"/>
            <!-- Committee list + buttons -->
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TITLE -->
        <Viewbox Grid.ColumnSpan="2"
                 Stretch="Uniform"
                 StretchDirection="Both"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Left">
            <TextBlock Style="{StaticResource H3}"
                       TextWrapping="Wrap"
                       TextAlignment="Left">
                <Run Text="{DynamicResource ConfigureBtn}"/>
            </TextBlock>
        </Viewbox>


        <!-- SELECTED COMMITTEE -->
        <Label Grid.Row="1" Grid.Column="0"
               Style="{StaticResource LeftAlignedLabelStyle}"
               Content="{DynamicResource SelCommittee}"/>
        <Label Grid.Row="1" Grid.Column="1"
               Style="{StaticResource LeftAlignedLabelStyle}"
               Content="{Binding SelectedCommittee.Name}"
               HorizontalAlignment="Left"
               Margin="40,0,0,0"
               Foreground="{DynamicResource TextPrimaryBrush}" />

        <!-- YEAR -->
        <Label Grid.Row="2" Grid.Column="0"
               Style="{StaticResource LeftAlignedLabelStyle}"
               Content="{DynamicResource YearLbl}"/>
        <TextBox x:Name="YearBox"  Grid.Row="2" Grid.Column="1"
                 Text="{Binding Source={x:Static properties:Settings.Default},
                                Path=Year,
                                Mode=TwoWay,
                                UpdateSourceTrigger=PropertyChanged}"
                 Margin="40,0,0,0"
                 VerticalContentAlignment="Center"
                 VerticalAlignment="Center" Padding="4"/>

        <!-- LANGUAGE LABEL -->
        <Label Grid.Row="3" Grid.Column="0"
               Style="{StaticResource LeftAlignedLabelStyle}"
               Content="{DynamicResource LanguageLbl}"/>

        <!-- LANGUAGE BUTTONS -->
        <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 10 0 0"
                    VerticalAlignment="Center">

            <RadioButton x:Name="EngLangButton" Margin="25 0"
                         Checked="EngLangButton_Checked">
                <StackPanel Orientation="Horizontal">
                    <svgc:SvgViewbox Width="18" Height="18"
                                     Source="pack://application:,,,/Resources/flags/gb.svg"
                                     Stretch="Uniform"
                                     Margin="0,0,10,4"/>
                    <TextBlock Text="English" FontSize="18"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="FraLangButton" Margin="25 0"
                         Checked="FraLangButton_Checked">
                <StackPanel Orientation="Horizontal">
                    <svgc:SvgViewbox Width="18" Height="18"
                               Source="pack://application:,,,/Resources/flags/fr.svg"
                               Stretch="Uniform"
                               Margin="0,0,10,4"/>
                    <TextBlock Text="Français" FontSize="18"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </RadioButton>

            <RadioButton x:Name="EspLangButton" Margin="25 0 0 0"
                         Checked="EspLangButton_Checked">
                <StackPanel Orientation="Horizontal">
                    <svgc:SvgViewbox Width="18" Height="18"
                               Source="pack://application:,,,/Resources/flags/es.svg"
                               Stretch="Uniform"
                               Margin="0,0,10,4"/>
                    <TextBlock Text="Español" FontSize="18"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </RadioButton>

        </StackPanel>

        <!-- COMMITTEE LABEL -->
        <Label Grid.Row="4" Grid.Column="0"
               Style="{StaticResource LeftAlignedLabelStyle}"
               Content="{DynamicResource CommitteeLbl}"/>

        <!-- COMMITTEE LIST -->
        <ListView x:Name="CommitteesListBox"
                  Grid.Row="5" Grid.Column="0"
                  ItemsSource="{Binding Committees}"
                  SelectedItem="{Binding SelectedCommittee, Mode=TwoWay}"
                  Background="{StaticResource InputBackgroundBrush}"
                  Foreground="{StaticResource TextInputBrush}"
                  Margin="0 0 40 0"
                  MinHeight="120"
                  SelectionMode="Single" Focusable="True">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}"
                   Foreground="{StaticResource TextInputBrush}"/>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextInputBrush}"/>
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Focusable" Value="True"/>

                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Background" Value="#22000000"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- ACTION BUTTONS -->
        <StackPanel Grid.Row="5" Grid.Column="1"
                    Orientation="Vertical" VerticalAlignment="Center"
>
            <!--ADD BUTTON-->
            <Button Style="{StaticResource MenuButton}" x:Name="AddButton"
                    Margin="40 0 0 4"
                    Command="{Binding AddCommitteeCommand}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Left">
                    <svgc:SvgViewbox Width="18" Height="18"
                               Source="pack://application:,,,/Resources/Icons/add.svg"
                               Stretch="Uniform"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="{DynamicResource AddBtn}" Padding="10 3"/>
                </StackPanel>
            </Button>

            <!--EDIT BUTTON-->
            <Button Style="{StaticResource MenuButton}" x:Name="EditButton"
                    Margin="40 0 0 4"
                    IsEnabled="{Binding IsEditCommitteeEnabled}"
                    Command="{Binding EditCommitteeCommand}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Left">
                    <svgc:SvgViewbox Width="18" Height="18"
                               Source="pack://application:,,,/Resources/Icons/edit.svg"
                               Stretch="Uniform"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="{DynamicResource EditBtn}" Padding="10 3"/>
                </StackPanel>
            </Button>

            <!--REMOVE BUTTON-->
            <Button Style="{StaticResource MenuButton}" x:Name="RemoveButton"
                    Margin="40 0 0 4"
                    IsEnabled="{Binding IsEditCommitteeEnabled}"
                    Command="{Binding RemoveCommitteeCommand}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Left">
                    <svgc:SvgViewbox Width="18" Height="18"
                               Source="pack://application:,,,/Resources/Icons/remove.svg"
                               Stretch="Uniform"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="{DynamicResource RemoveBtn}" Padding="10 3"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Page>