<Page x:Class="Foscamun2026.Views.AddICJPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
      xmlns:conv="clr-namespace:Foscamun2026.Converters"
      mc:Ignorable="d"
      d:DesignWidth="800"
      d:DesignHeight="500"
      Background="{DynamicResource PrimaryBrush}"
      Foreground="{DynamicResource TextPrimaryBrush}"
      Title="AddICJPage">

    <Page.Resources>
        <conv:EditAddTitleConverter x:Key="EditAddTitleConverter"/>
    </Page.Resources>


    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITOLO -->
        <TextBlock Text="International Court of Justice"
                   Style="{StaticResource H3}"
                   Margin="0 0 0 25"/>

        <!-- CONTENUTO -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*">

            <!-- COLONNA 1: Topic, President, Moderator -->
            <Grid Grid.Column="0" Margin="0 0 20 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="3*"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>


                <TextBlock Grid.Row="0" Text="Topic"
                           Style="{StaticResource Caption}"/>
                <TextBox Grid.Row="1" Text="{Binding TopicA}"
                         Style="{StaticResource InputBoxStyle}"
                         Margin="0 5 0 15"/>

                <TextBlock Grid.Row="2" Text="President"
                           Style="{StaticResource Caption}"/>
                <TextBox Grid.Row="3" Text="{Binding President}"
                         Style="{StaticResource InputBoxStyle}"
                         Margin="0 5 0 15"/>

                <TextBlock Grid.Row="4" Text="Moderator"
                           Style="{StaticResource Caption}"/>
                <TextBox Grid.Row="5" Text="{Binding Moderator}"
                         Style="{StaticResource InputBoxStyle}"
                         Margin="0 5 0 15"/>

            </Grid>

            <!-- COLONNA 2: Available Countries -->
            <Grid Grid.Column="1" Margin="20 0 20 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Available Countries"
                           Style="{StaticResource Caption}"/>

                <ListBox Grid.Row="1" ItemsSource="{Binding AvailableCountries}"
                         SelectedItem="{Binding SelectedCountry}"
                         Style="{StaticResource ListBoxStyle}"
                         ItemTemplate="{StaticResource CountryTemplate}"
                         MouseLeftButtonUp="AvailableCountries_Click"
                         Margin="0 5 0 15"/>
            </Grid>

            <!-- COLONNA 3: Assigned Countries -->
            <Grid Grid.Column="2" Margin="20 0 0 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Assigned Countries"
                           Style="{StaticResource Caption}"/>

                <ListBox Grid.Row="1" ItemsSource="{Binding SelectedCountries}"
                         SelectedItem="{Binding SelectedCountry}"
                         Style="{StaticResource ListBoxStyle}"
                         ItemTemplate="{StaticResource CountryTemplate}"
                         MouseLeftButtonUp="SelectedCountries_Click"
                         Margin="0 5 0 15"/>
            </Grid>

        </Grid>

        <!-- FOOTER -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>


            <Button Style="{StaticResource IconButton}" Grid.Column="0"
                    Tag="pack://application:,,,/Resources/Icons/add.svg"
                    Content="Add Member"
                    Command="{Binding AddMemberCommand}"
                    HorizontalAlignment="Left"/>

            <Button Style="{StaticResource IconButton}" Grid.Column="1"
                    Tag="pack://application:,,,/Resources/Icons/close.svg"
                    Content="Cancel"
                    Command="{Binding CancelCommand}"
                    HorizontalAlignment="Right"
                    Margin="0 0 10 0"/>

            <Button Style="{StaticResource IconButton}" Grid.Column="2"
                    Tag="pack://application:,,,/Resources/Icons/check.svg"
                    Content="Save"
                    Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                    Margin="10 0 0 0"
                    HorizontalAlignment="Right"/>
        </Grid>

    </Grid>
</Page>