<Window x:Class="Foscamun2026.StartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Start Committee"
        Height="450" Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Committee Start"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0 0 0 20"/>

            <TextBlock Text="Select an option to begin:"
                       FontSize="16"
                       Margin="0 0 0 20"/>

            <Button Content="Open Roll Call"
                    Width="200"
                    Height="40"
                    Margin="0 0 0 10"
                    Click="RollCall_Click"/>

            <Button Content="Open Voting"
                    Width="200"
                    Height="40"
                    Margin="0 0 0 10"
                    Click="Voting_Click"/>

            <Button Content="Back"
                    Width="200"
                    Height="40"
                    Click="Back_Click"/>
        </StackPanel>
    </Grid>
</Window>
