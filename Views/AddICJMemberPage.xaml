<Page x:Class="Foscamun2026.Views.AddICJMemberPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignWidth="800"
      d:DesignHeight="500"
      Background="{DynamicResource FoscamunBlue}"
      Foreground="{DynamicResource FoscamunWhite}"
      Title="AddICJMemberPage">

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- Colonna sinistra -->
            <ColumnDefinition Width="*"/>
            <!-- Colonna destra -->
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <!-- Contenuto -->
            <RowDefinition Height="Auto"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ========================= -->
        <!-- COLONNA SINISTRA          -->
        <!-- ========================= -->
        <StackPanel Grid.Column="0" VerticalAlignment="Top">

            <!-- ADD JUROR -->
            <GroupBox Header="Add Juror"
                      Margin="0 0 0 20"
                      Padding="10"
                      BorderBrush="#FFCCCCCC"
                      BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="Name:"/>
                    <TextBox Text="{Binding JurorName}"
                             Style="{StaticResource InputBoxStyle}"
                             Margin="0 5 0 10"/>

                    <Button Content="Add Juror"
                            Command="{Binding AddJurorCommand}"
                            Style="{StaticResource MenuButton}" HorizontalAlignment="Center"/>
                </StackPanel>
            </GroupBox>
            
            <!-- ADD LAWYER -->
            <GroupBox Header="Add Lawyer"
                      Margin="0 0 0 20"
                      Padding="10"
                      BorderBrush="#FFCCCCCC"
                      BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="Name:"/>

                    <TextBox Text="{Binding LawyerName}"
                             Style="{StaticResource InputBoxStyle}"
                             Margin="0 5 0 10"/>

                    <Button Content="Add Lawyer"
                            Command="{Binding AddLawyerCommand}"
                            Style="{StaticResource MenuButton}" HorizontalAlignment="Center"/>
                </StackPanel>

            </GroupBox>
        </StackPanel>

        <!-- ========================= -->
        <!-- COLONNA DESTRA            -->
        <!-- ========================= -->
        <GroupBox Header="ICJ Members" Grid.Column="1" VerticalAlignment="Top"
                  Padding="10"
                  BorderBrush="#FFCCCCCC"
                  BorderThickness="1"
                  Margin="40 0 0 0">

            <StackPanel>

                <ListBox ItemsSource="{Binding Members}"
                 SelectedItem="{Binding SelectedMember}"
                 Style="{StaticResource ListBoxStyle}"
                 Height="300"/>

                <Button Content="Remove Member"
                Command="{Binding RemoveMemberCommand}"
                Style="{StaticResource MenuButton}"
                Margin="0 10 0 0"/>

            </StackPanel>

        </GroupBox>
        <!-- ========================= -->
        <!-- FOOTER (BACK)             -->
        <!-- ========================= -->
        <StackPanel Grid.Row="1"
                    Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 20 0 0">

            <Button Content="Back"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource MenuButton}"/>
        </StackPanel>

    </Grid>
</Page>