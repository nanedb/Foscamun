<Window x:Class="Foscamun2026.Views.TimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="{DynamicResource TimerWindowTitle}" Height="400" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource PrimaryBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        KeyDown="Window_KeyDown">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Time Settings -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
            <TextBlock Text="Minutes:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="16"/>
            <TextBox x:Name="MinutesInput" Width="60" Height="32" Margin="0,0,20,0" 
                     FontSize="18" TextAlignment="Center" Text="0"
                     Background="{StaticResource InputBackgroundBrush}"
                     Foreground="{StaticResource TextInputBrush}"
                     VerticalContentAlignment="Center"/>

            <TextBlock Text="Seconds:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="16"/>
            <TextBox x:Name="SecondsInput" Width="60" Height="32"
                     FontSize="18" TextAlignment="Center" Text="0"
                     Background="{StaticResource InputBackgroundBrush}"
                     Foreground="{StaticResource TextInputBrush}"
                     VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- Timer Display -->
        <Border Grid.Row="1" x:Name="TimerBorder"
                Background="Transparent"
                CornerRadius="8"
                Padding="15">
            <TextBlock x:Name="TimeText"
                       Text="00:00"
                       FontSize="56"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="SetBtn" Click="SetBtn_Click" Style="{StaticResource MenuButton}" Margin="4" Padding="12,8" MinWidth="80">
                <StackPanel Orientation="Horizontal">
                    <svgc:SvgViewbox Width="16" Height="16"
                                     Source="pack://application:,,,/Resources/Icons/set.svg"
                                     Stretch="Uniform"
                                     Margin="0,0,8,0"/>
                    <TextBlock Text="{DynamicResource SetBtn}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button x:Name="StartPauseBtn" Click="StartPauseBtn_Click" Style="{StaticResource MenuButton}" Margin="4" Padding="12,8" MinWidth="80">
                <StackPanel Orientation="Horizontal">
                    <svgc:SvgViewbox x:Name="StartPauseIcon" Width="16" Height="16"
                                     Source="pack://application:,,,/Resources/Icons/start.svg"
                                     Stretch="Uniform"
                                     Margin="0,0,8,0"/>
                    <TextBlock x:Name="StartPauseText" Text="{DynamicResource StartBtn}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button x:Name="ResetBtn" Click="ResetBtn_Click" Style="{StaticResource MenuButton}" Margin="4" Padding="12,8" MinWidth="80">
                <StackPanel Orientation="Horizontal">
                    <svgc:SvgViewbox Width="16" Height="16"
                                     Source="pack://application:,,,/Resources/Icons/reset.svg"
                                     Stretch="Uniform"
                                     Margin="0,0,8,0"/>
                    <TextBlock Text="{DynamicResource ResetBtn}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Close Button -->
        <Button Grid.Row="3" x:Name="CloseBtn" Click="CloseBtn_Click" 
                Style="{StaticResource MenuButton}" 
                HorizontalAlignment="Center" 
                Margin="0,10,0,0" 
                Padding="12,8" 
                MinWidth="100">
            <StackPanel Orientation="Horizontal">
                <svgc:SvgViewbox Width="16" Height="16"
                                 Source="pack://application:,,,/Resources/Icons/close.svg"
                                 Stretch="Uniform"
                                 Margin="0,0,8,0"/>
                <TextBlock Text="{DynamicResource CloseBtn}" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
    </Grid>
</Window>
