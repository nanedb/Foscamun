<Window x:Class="Foscamun2026.Views.TimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Timer" Height="280" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource PrimaryBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Time Settings -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
            <TextBlock Text="Minutes:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="16"/>
            <TextBox x:Name="MinutesInput" Width="60" Height="32" Margin="0,0,20,0" 
                     FontSize="18" TextAlignment="Center" Text="0"
                     Background="{StaticResource InputBackgroundBrush}"
                     Foreground="{StaticResource TextInputBrush}"
                     VerticalContentAlignment="Center"/>

            <TextBlock Text="Seconds:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="16"/>
            <TextBox x:Name="SecondsInput" Width="60" Height="32"
                     FontSize="18" TextAlignment="Center" Text="0"
                     Background="{StaticResource InputBackgroundBrush}"
                     Foreground="{StaticResource TextInputBrush}"
                     VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- Timer Display -->
        <Border Grid.Row="1" x:Name="TimerBorder"
                Background="Transparent"
                CornerRadius="8"
                Padding="15">
            <TextBlock x:Name="TimeText"
                       Text="00:00"
                       FontSize="56"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="SetBtn" Click="SetBtn_Click" Style="{StaticResource MenuButton}" Margin="4" Padding="12,8" MinWidth="80">Set</Button>
            <Button x:Name="StartBtn" Click="StartBtn_Click" Style="{StaticResource MenuButton}" Margin="4" Padding="12,8" MinWidth="80">Start</Button>
            <Button x:Name="PauseBtn" Click="PauseBtn_Click" Style="{StaticResource MenuButton}" Margin="4" Padding="12,8" MinWidth="80">Pause</Button>
            <Button x:Name="ResetBtn" Click="ResetBtn_Click" Style="{StaticResource MenuButton}" Margin="4" Padding="12,8" MinWidth="80">Reset</Button>
        </StackPanel>
    </Grid>
</Window>
