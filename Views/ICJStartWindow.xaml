<Window x:Class="Foscamun2026.ICJStartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ICJ - Start"
        Height="450" Width="700"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="International Court of Justice"
                       FontSize="26"
                       FontWeight="Bold"
                       Margin="0 0 0 20"/>

            <TextBlock Text="Select an option to begin:"
                       FontSize="16"
                       Margin="0 0 0 20"/>

            <Button Content="Start Case"
                    Width="200"
                    Height="40"
                    Margin="0 0 0 10"
                    Click="StartCase_Click"/>

            <Button Content="Back"
                    Width="200"
                    Height="40"
                    Click="Back_Click"/>
        </StackPanel>
    </Grid>
</Window>
