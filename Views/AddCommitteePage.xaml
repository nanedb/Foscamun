<Page x:Class="Foscamun2026.Views.AddCommitteePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:models="clr-namespace:Foscamun2026.Models"
      xmlns:vm="clr-namespace:Foscamun2026.ViewModels"
      mc:Ignorable="d"
      d:DesignHeight="500"
      d:DesignWidth="800"
      d:DataContext="{d:DesignInstance Type=vm:AddCommitteeViewModel, IsDesignTimeCreatable=False}"
      Title="AddCommitteePage"
      Background="{DynamicResource FoscamunBlue}"
      Foreground="{DynamicResource FoscamunWhite}"
      FontFamily ="{DynamicResource FontPrimary}"
      FontSize="18"
>

    <Page.Resources>

        <!-- Template corretto: Country è nel namespace Models -->
        <DataTemplate x:Key="CountryTemplate" DataType="models:Country">
            <StackPanel Orientation="Horizontal">
                <Image Source="{Binding SmallFlagPath}"
                       Margin="0,0,5,0"
                       VerticalAlignment="Center" />
                <TextBlock Text="{Binding EnglishName}"
                           Margin="5,0,0,0"
                           VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="15" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="15" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="15" />
            <RowDefinition Height="12*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="15" />
        </Grid.RowDefinitions>

        <Grid Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="3*" />
                <RowDefinition Height="3*" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <!-- Titoli -->
            <TextBlock Grid.Column="2" Grid.Row="0" Margin="5"
                       Text="Click to add Country to Committee"
                       FontSize="14" TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <TextBlock Grid.Column="3" Grid.Row="0" Margin="5"
                       Text="Click to remove Country from Committee"
                       FontSize="14" TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <!-- Campi testo -->
            <TextBlock Grid.Column="0" Grid.Row="1" Margin="5"
                       Text="Committee" HorizontalAlignment="Right"
                       VerticalAlignment="Center" />

            <TextBox Grid.Column="1" Grid.Row="1" Margin="5"
                     Text="{Binding Committee.Name, Mode=OneWayToSource}"
                     Background="{DynamicResource FoscamunWhite}" />

            <TextBlock Grid.Column="0" Grid.Row="2" Margin="5"
                       Text="Topic A" HorizontalAlignment="Right"
                       VerticalAlignment="Center" />

            <TextBox Grid.Column="1" Grid.Row="2" Margin="5"
                     Text="{Binding Committee.TopicA, Mode=OneWayToSource}"
                     TextWrapping="Wrap"
                     Background="{DynamicResource FoscamunWhite}" />

            <TextBlock Grid.Column="0" Grid.Row="3" Margin="5"
                       Text="Topic B" HorizontalAlignment="Right"
                       VerticalAlignment="Center" />

            <TextBox Grid.Column="1" Grid.Row="3" Margin="5"
                     Text="{Binding Committee.TopicB, Mode=OneWayToSource}"
                     TextWrapping="Wrap"
                     Background="{DynamicResource FoscamunWhite}" />

            <TextBlock Grid.Column="0" Grid.Row="4" Margin="5"
                       Text="President" HorizontalAlignment="Right"
                       VerticalAlignment="Center" />

            <TextBox Grid.Column="1" Grid.Row="4" Margin="5"
                     Text="{Binding Committee.President, Mode=OneWayToSource}"
                     Background="{DynamicResource FoscamunWhite}" />

            <TextBlock Grid.Column="0" Grid.Row="5" Margin="5"
                       Text="Vice President" HorizontalAlignment="Right"
                       VerticalAlignment="Center" />

            <TextBox Grid.Column="1" Grid.Row="5" Margin="5"
                     Text="{Binding Committee.VicePresident, Mode=OneWayToSource}"
                     Background="{DynamicResource FoscamunWhite}" />

            <TextBlock Grid.Column="0" Grid.Row="6" Margin="5"
                       Text="Moderator" HorizontalAlignment="Right"
                       VerticalAlignment="Center" />

            <TextBox Grid.Column="1" Grid.Row="6" Margin="5"
                     Text="{Binding Committee.Moderator, Mode=OneWayToSource}"
                     Background="{DynamicResource FoscamunWhite}" />

            <!-- Liste -->
            <ListView ItemsSource="{Binding AllCountries}"
                      Grid.Column="2" Grid.Row="1" Grid.RowSpan="6"
                      Margin="5"
                      MinWidth="200"
                      MaxWidth="200"
                      ItemTemplate="{StaticResource CountryTemplate}"
                      Background="{DynamicResource FoscamunWhite}" />

            <ListView ItemsSource="{Binding SelectedCountries}"
                      Grid.Column="3" Grid.Row="1" Grid.RowSpan="6"
                      Margin="5"
                      MinWidth="200"
                      MaxWidth="200"
                      ItemTemplate="{StaticResource CountryTemplate}"
                      Background="{DynamicResource FoscamunWhite}" />

        </Grid>

    </Grid>
</Page>