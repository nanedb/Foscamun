<UserControl x:Class="Foscamun2026.Views.CommitteeListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="20">
        <Button Content="Carica Comitati"
                Command="{Binding LoadCommitteesAsyncCommand}"
                Margin="0,0,0,10"/>
        <Button Content="Aggiungi Comitato"
                Command="{Binding AddCommitteeAsyncCommand}"
                Margin="0,0,0,20"/>
        <DataGrid ItemsSource="{Binding Committees}" AutoGenerateColumns="True" Height="200"/>
    </StackPanel>
</UserControl>