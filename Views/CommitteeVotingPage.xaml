<Page x:Class="Foscamun2026.Views.CommitteeVotingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
      mc:Ignorable="d"
      d:DesignWidth="900"
      d:DesignHeight="600"
      Background="{DynamicResource PrimaryBrush}"
      Foreground="{DynamicResource TextPrimaryBrush}"
      Title="Cast Vote">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,30">
            <TextBlock Text="Voting" 
                       Style="{StaticResource H1}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
            <TextBlock x:Name="RoundTextBlock"
                       Style="{StaticResource H2}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Current Voter -->
        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <svgc:SvgViewbox Grid.Column="0"
                             x:Name="CurrentVoterFlag"
                             Width="120" Height="82"
                             Stretch="Uniform"
                             VerticalAlignment="Center"
                             Margin="0,0,30,0"/>

            <TextBlock Grid.Column="1"
                       x:Name="CurrentVoterText"
                       Style="{StaticResource H1}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="400"/>
        </Grid>

        <!-- Voting Buttons -->
        <UniformGrid Grid.Row="2" Columns="3" Margin="0,30,0,0"
                     HorizontalAlignment="Center"
                     MaxWidth="600">
            <Button x:Name="FavorBtn"
                    Click="FavorBtn_Click"
                    Style="{StaticResource MenuButton}"
                    Margin="0,0,10,0"
                    Padding="30,15">
                <TextBlock Text="{DynamicResource ApproveBtn}"
                           FontSize="18"
                           HorizontalAlignment="Center"/>
            </Button>

            <Button x:Name="AbstainBtn"
                    Click="AbstainBtn_Click"
                    Style="{StaticResource MenuButton}"
                    Margin="5,0,5,0"
                    Padding="30,15">
                <TextBlock Text="{DynamicResource AbstainBtn}"
                           FontSize="18"
                           HorizontalAlignment="Center"/>
            </Button>

            <Button x:Name="AgainstBtn"
                    Click="AgainstBtn_Click"
                    Style="{StaticResource MenuButton}"
                    Margin="10,0,0,0"
                    Padding="30,15">
                <TextBlock Text="{DynamicResource RejectBtn}"
                           FontSize="18"
                           HorizontalAlignment="Center"/>
            </Button>
        </UniformGrid>
    </Grid>
</Page>
