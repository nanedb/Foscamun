<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Titres -->
    <sys:String x:Key="WelcomeMessage">Bienvenue à Foscamun </sys:String>
    <sys:String x:Key="ConfigurationTitle">Configuration</sys:String>
    <sys:String x:Key="SelCommittee">Comité sélectionné:</sys:String>
    <sys:String x:Key="YearLbl">Sélectionner l'année:</sys:String>
    <sys:String x:Key="LanguageLbl">Choisir la langue:</sys:String>
    <sys:String x:Key="CommitteeLbl">Choisir le comité:</sys:String>

    <!-- Boutons -->
    <sys:String x:Key="HomeBtn">Home</sys:String>
    <sys:String x:Key="AddBtn">Ajouter</sys:String>
    <sys:String x:Key="EditBtn">Modifier</sys:String>
    <sys:String x:Key="RemoveBtn">Supprimer</sys:String>
    <sys:String x:Key="BackBtn">Retour</sys:String>
    <sys:String x:Key="NextBtn">Suivant</sys:String>
    <sys:String x:Key="ExitBtn">Quitter</sys:String>
    <sys:String x:Key="ConfigureBtn">Configurer</sys:String>
    <sys:String x:Key="CloseBtn">Fermer</sys:String>

    <!-- ToolTips -->
    <sys:String x:Key="HamburgerBtn">Ouvrir/Fermer le menu</sys:String>

</ResourceDictionary>