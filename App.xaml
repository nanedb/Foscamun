<Application x:Class="Foscamun2026.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <Application.Resources>
        <ResourceDictionary>
            
             <!-- 🌍 Stili impliciti globali -->
            <Style TargetType="Window">
                <Setter Property="FontFamily" Value="{StaticResource AkkoProRegular}"/>
                <Setter Property="FontSize" Value="18"/>
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AkkoProRegular}"/>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="FontFamily" Value="{StaticResource AkkoProRegular}"/>
            </Style>

            <!-- Style che imposta il ToolTip solo quando IsPaneCollapsed == True -->
            <Style x:Key="IconTooltipWhenCollapsed" TargetType="Button" BasedOn="{StaticResource MenuButton}">
                <Setter Property="ToolTip" Value="{x:Null}"/>
                <Style.Triggers>
                    <!-- Se la proprietà IsPaneCollapsed (ElementName=Root) è true, usa il Tag come ToolTip -->
                    <DataTrigger Binding="{Binding IsPaneCollapsed, ElementName=Root}" Value="True">
                        <Setter Property="ToolTip" Value="{Binding Tag, RelativeSource={RelativeSource Self}}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <sys:String x:Key="WelcomePrefix">Welcome to Foscamun</sys:String>
            <sys:String x:Key="YearResource">2026</sys:String>

            <ResourceDictionary.MergedDictionaries>

                <!-- Colors -->
                <ResourceDictionary Source="Styles/Colors.xaml"/>

                <!-- Fonts -->
                <ResourceDictionary Source="Fonts/Fonts.xaml"/>

                <!-- Icons -->
                <ResourceDictionary Source="Styles/Icons.xaml"/>

                <!-- Theme -->
                <ResourceDictionary Source="Styles/Theme.xaml"/>

                <!-- Buttons -->
                <ResourceDictionary Source="Styles/Buttons.xaml"/>

                <!-- Strings -->
                <ResourceDictionary Source="Strings/Strings.en.xaml"/>

            </ResourceDictionary.MergedDictionaries>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>