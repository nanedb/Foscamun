<Application x:Class="Foscamun2026.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:models="clr-namespace:Foscamun2026.Models"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <Application.Resources>
        
        <ResourceDictionary>
            
             <!-- 🌍 Stili impliciti globali -->
            <Style TargetType="Window">
                <Setter Property="FontFamily" Value="{StaticResource AkkoProRegular}"/>
                <Setter Property="FontSize" Value="18"/>
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AkkoProRegular}"/>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="FontFamily" Value="{StaticResource AkkoProRegular}"/>
            </Style>

            <sys:String x:Key="WelcomePrefix">Welcome to Foscamun</sys:String>
            <sys:String x:Key="YearResource">2026</sys:String>

            <DataTemplate x:Key="CountryTemplate" DataType="models:Country">
                <StackPanel Orientation="Horizontal" Margin="4">
                    <svgc:SvgViewbox Width="24" Height="24"
                                 Source="{Binding FlagPath}"
                                 VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Name}"
                           Margin="5,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="14" />
                </StackPanel>
            </DataTemplate>

            <ResourceDictionary.MergedDictionaries>

                <!-- Colors -->
                <ResourceDictionary Source="Styles/Colors.xaml"/>

                <!-- Fonts -->
                <ResourceDictionary Source="Fonts/Fonts.xaml"/>

                <!-- Buttons -->
                <ResourceDictionary Source="Styles/Buttons.xaml"/>

                <!-- Icons -->
                <ResourceDictionary Source="Styles/Icons.xaml"/>

                <!-- Theme -->
                <ResourceDictionary Source="Styles/Theme.xaml"/>

                <!-- Strings -->
                <ResourceDictionary Source="Strings/Strings.en.xaml"/>

            </ResourceDictionary.MergedDictionaries>
            
        </ResourceDictionary>


    </Application.Resources>
    
</Application>