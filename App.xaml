<Application x:Class="Foscamun2026.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Dizionari di stile -->
                <ResourceDictionary Source="Styles/Colors.xaml"/>
                <ResourceDictionary Source="Styles/Buttons.xaml"/>
                
                <!-- Dizionario di stringhe (default en) -->
                <ResourceDictionary Source="Resources/Strings.en.xaml"/>
            </ResourceDictionary.MergedDictionaries>


            <!-- 🖋 Stile globale per TextBlock -->
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="pack://application:,,,/Resources/Fonts/#Akko Pro"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
