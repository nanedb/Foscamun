<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">

    <!-- ========================================================= -->
    <!--                     BASE STYLE PER INPUT                  -->
    <!-- ========================================================= -->
    <Style x:Key="InputBaseStyle" TargetType="Control">
        <Setter Property="FontFamily" Value="{StaticResource FontPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="{StaticResource InputPadding}"/>
        <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextInputBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ========================================================= -->
    <!--                           TEXTBOX                         -->
    <!-- ========================================================= -->
    <Style TargetType="TextBox" BasedOn="{StaticResource InputBaseStyle}">
        <Setter Property="Foreground" Value="{StaticResource TextInputBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource TextInputBrush}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource CornerRadiusMedium}">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource SurfaceBorderHoverBrush}"/>
                        </Trigger>

                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource SurfaceBorderFocusBrush}"/>
                            <Setter TargetName="Border" Property="BorderThickness" Value="1.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================================================= -->
    <!--                          COMBOBOX                         -->
    <!-- ========================================================= -->
    <DataTemplate x:Key="CountryTemplate">
        <StackPanel Orientation="Horizontal">
            <svgc:SvgViewbox Width="24" Height="16"
                         Source="{Binding FlagPath}"
                         Stretch="Uniform"/>
            <TextBlock Text="{Binding Name}"
                   Margin="8 0 0 0"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource TextInputBrush}"/>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="CountrySelectedTemplate">
        <StackPanel Orientation="Horizontal">
            <svgc:SvgViewbox Width="24" Height="16"
                         Source="{Binding FlagPath}"
                         Stretch="Uniform"/>
            <TextBlock Text="{Binding Name}"
                   Margin="10 0 0 0"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource TextInputBrush}"/>
        </StackPanel>
    </DataTemplate>
    
    <Style TargetType="ComboBox" BasedOn="{StaticResource InputBaseStyle}">
        <Setter Property="Foreground" Value="{StaticResource TextInputBrush}"/>
        <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="MinHeight" Value="32"/>

        <Setter Property="ItemTemplate" Value="{StaticResource CountryTemplate}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- BOX PRINCIPALE -->
                        <Border x:Name="Border"
                            Background="{StaticResource InputBackgroundBrush}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource CornerRadiusMedium}"
                            Padding="4"
                            SnapsToDevicePixels="True"/>

                        <!-- CONTENUTO -->
                        <ContentPresenter x:Name="ContentSite"
                                          Margin="4,0,24,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          RecognizesAccessKey="True"
                                          Content="{TemplateBinding SelectedItem}"
                                          ContentTemplate="{StaticResource CountrySelectedTemplate}"/>
                        
                        <!-- FRECCIA + TOGGLEBUTTON -->
                        <ToggleButton x:Name="ToggleButton"
                                  Grid.Column="1"
                                  Focusable="False"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Width="25" Height="25"
                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                            <Path Width="10" Height="6"
                              Fill="{StaticResource TextInputBrush}"
                              Data="M 0 0 L 10 0 L 5 6 Z"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                        </ToggleButton>

                        <!-- POPUP -->
                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               PopupAnimation="Slide"
                               Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                            <Border Background="{StaticResource InputBackgroundBrush}"
                                    BorderBrush="{StaticResource SurfaceBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource CornerRadiusMedium}"
                                    Padding="4">
                                <ScrollViewer>
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource SurfaceBorderHoverBrush}"/>
                        </Trigger>

                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource SurfaceBorderFocusBrush}"/>
                            <Setter TargetName="Border" Property="BorderThickness" Value="1.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        
    </Style>

    <!-- ========================================================= -->
    <!--                BASE STYLE PER TUTTE LE LISTE             -->
    <!-- ========================================================= -->
    <Style x:Key="BaseListStyle" TargetType="ItemsControl">
        <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Foreground" Value="{StaticResource TextInputBrush}"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <!-- ========================================================= -->
    <!--                          LISTVIEW                         -->
    <!-- ========================================================= -->
    <Style TargetType="ListView" BasedOn="{StaticResource BaseListStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListView">
                    <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="0">
                        <ScrollViewer Focusable="False"
                                  Padding="{TemplateBinding Padding}">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!--ListViewItem-->
    <Style TargetType="ListViewItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextInputBrush}"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="0">
                        <ContentPresenter Margin="4,2"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FFE0E0D6"/>
                        </Trigger>

                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FFD6D6C8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
