<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 🎨 Palette colori -->

    <Color x:Key="FoscamunBlueColor">#FF5598D3</Color>
    <Color x:Key="FoscamunWhiteColor">#FFF2F2EA</Color>

    <SolidColorBrush x:Key="FoscamunBlue" Color="{StaticResource FoscamunBlueColor}"/>
    <SolidColorBrush x:Key="FoscamunWhite" Color="{StaticResource FoscamunWhiteColor}"/>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource FoscamunBlueColor}"/>
    <SolidColorBrush x:Key="PrimaryBrushLight" Color="#0059b3"/>
    <SolidColorBrush x:Key="PrimaryBrushDark" Color="#003366"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource FoscamunWhiteColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#FF9800"/>
    
</ResourceDictionary>